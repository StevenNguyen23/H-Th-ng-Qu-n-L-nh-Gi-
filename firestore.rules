rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'AMZeFZGUWVe483YN8VJmmlDJMHD2' || 
        ('email' in request.auth.token && ('email' in request.auth.token && request.auth.token.email == 'minhhoangbluesky6789@gmail.com')) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isDeactivated() {
      return !isAdmin() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', '') == 'deactivated';
    }
    function canAccess() {
      return isSignedIn() && !isDeactivated();
    }
    function isTeacher() {
      return canAccess() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'teacher' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'specialist');
    }

    match /users/{userId} {
      allow get: if isAdmin() || (canAccess() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow create: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow create: if (isSignedIn() && request.auth.uid == teacherId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    function isSpecialist() {
      return canAccess() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'specialist';
    }

    match /submissions/{submissionId} {
      allow get: if isAdmin() || isTeacher();
      allow list: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin() || isTeacher();
      allow create: if true;
    }

    match /files/{fileId} {
      allow get: if isAdmin() || (canAccess() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (canAccess() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (canAccess() && request.resource.data.userId == request.auth.uid);
    }

    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
